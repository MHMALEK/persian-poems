# Local testing: copy to .env, set TELEGRAM_BOT_TOKEN + MONGODB_URL, then `npm start`.
# `npm start` uses polling (no HTTPS tunnel). WEBHOOK_URL is not required locally.

# --- Bot token (use TELEGRAM_BOT_TOKEN in production / Docker; GitHub secret same name) ---
TELEGRAM_BOT_TOKEN=

# Legacy (local dev): if TELEGRAM_BOT_TOKEN is unset, dev uses TELEGRAM_BOT_API_TOKEN_DEV
# TELEGRAM_BOT_API_TOKEN_DEV=

# --- MongoDB ---
MONGODB_URL=
# Legacy alias still supported:
# MANGO_DB_URL=

# --- Webhook (production / Docker / ngrok). HTTPS. Path optional: if missing, /telegram/webhook is used ---
WEBHOOK_URL=
# Optional: default path when WEBHOOK_URL has no path (default /telegram/webhook)
# WEBHOOK_PATH=/telegram/webhook
# Optional: Telegram sends X-Telegram-Bot-Api-Secret-Token; must match setWebhook secret_token
TELEGRAM_WEBHOOK_SECRET=

# --- Server ---
# Inside-container port (default 3000). Do not change unless you change Dockerfile/healthcheck.
PORT=3000
# Docker Compose: host port on the VM (default 3002). GitHub deploy uses 3002:3000.
# PUBLISH_PORT=3002

# polling | webhook — default: polling in development, webhook when NODE_ENV=production
# BOT_TRANSPORT=polling

# --- Test webhooks locally with ngrok ---
# `npm run start:webhook` will crash until WEBHOOK_URL is set (non-empty) in .env.
# 1. In .env set PORT=3000 (or match ngrok below).
# 2. Terminal A:  ngrok http 3000
# 3. Copy the "Forwarding" https URL (e.g. https://xxxx.ngrok-free.app).
# 4. Put it in .env as WEBHOOK_URL with a path (required), e.g.:
#    WEBHOOK_URL=https://xxxx.ngrok-free.app/telegram/webhook
# 5. Optional: TELEGRAM_WEBHOOK_SECRET=<long random string> (same value in .env for grammY).
# 6. Terminal B:  npm run start:webhook
# 7. Open https://xxxx.ngrok-free.app/health in a browser — should show "ok".
# 8. Message your bot on Telegram; updates hit ngrok → your app.
#
# Before switching back to polling (`npm start`), clear the webhook:
#   curl "https://api.telegram.org/bot<YOUR_BOT_TOKEN>/deleteWebhook"

# Optional error tracking (production)
# SENTRY_DSN=

# --- GitHub Actions: .github/workflows/deploy.yml (same pattern as telegram-iranian-money-exchange-bot) ---
# Secrets: VM_HOST, VM_USER, VM_SSH_KEY, TELEGRAM_BOT_TOKEN, WEBHOOK_URL, MONGODB_URL or DATABASE_URL
# Optional: TELEGRAM_WEBHOOK_SECRET
# Make the GHCR package Public after first push so the VM can docker pull without login.
